# Database connection
DATABASE_URL=postgresql+asyncpg://decodr:decodr@localhost:5435/decodr

# Google API key — used for both Gemini LLM and YouTube Data API v3
GOOGLE_API_KEY=your-google-api-key-here

# Optional: separate YouTube Data API key (falls back to GOOGLE_API_KEY if not set)
# YOUTUBE_API_KEY=your-youtube-data-api-key-here

# Optional: AssemblyAI for cloud transcription fallback (Whisper runs locally without this)
ASSEMBLYAI_API_KEY=your-assemblyai-key-here

# LLM model (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# CORS origins (comma-separated, update for production)
CORS_ORIGINS=http://localhost:3000
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
WHISPER_MODEL=tiny
CHUNK_SIZE=500
CHUNK_OVERLAP=100
GEMINI_MODEL=gemini-2.5-flash